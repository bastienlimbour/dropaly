{
  "name": "@dropaly/mobile",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "uniwind:generate": "uniwind generate-artifacts --css ./src/styles/index.css --dts ./uniwind-types.d.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "prebuild": "expo prebuild",
    "dev": "expo start --clear",
    "start": "pnpm run uniwind:generate && expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "clean": "git clean -xdf .cache .expo .turbo dist node_modules"
  },
  "dependencies": {
    "@ai-sdk/react": "catalog:ai",
    "@better-auth/expo": "catalog:auth",
    "@dropaly/api-client": "workspace:*",
    "@dropaly/api-query": "workspace:*",
    "@dropaly/ui-mobile": "workspace:*",
    "@expo-google-fonts/nunito-sans": "^0.4.2",
    "@expo-google-fonts/outfit": "^0.4.3",
    "@rn-primitives/portal": "^1.4.0",
    "@stardazed/streams-text-encoding": "^1.0.2",
    "@t3-oss/env-core": "catalog:runtime",
    "@tabler/icons-react-native": "catalog:ui",
    "@tanstack/react-form": "catalog:tanstack",
    "@tanstack/react-query": "catalog:tanstack",
    "@types/ungap__structured-clone": "^1.2.0",
    "@ungap/structured-clone": "^1.3.2",
    "ai": "catalog:ai",
    "better-auth": "catalog:auth",
    "expo": "~56.0.12",
    "expo-constants": "~56.0.18",
    "expo-dev-client": "~56.0.20",
    "expo-font": "~56.0.7",
    "expo-haptics": "~56.0.3",
    "expo-linking": "~56.0.14",
    "expo-network": "~56.0.5",
    "expo-router": "~56.2.11",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "react": "catalog:react",
    "react-native": "catalog:native",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-keyboard-controller": "1.21.6",
    "react-native-reanimated": "catalog:native",
