{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@dropaly/config/typescript/tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "types": ["vite/client", "react", "react-dom"],
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "**/*.js"],
  "exclude": ["node_modules", "dist", "dev-dist"]
}
