{
  "expo": {
    "name": "Dropaly",
    "description": "Dropaly is an app for capturing and structuring thoughts into tasks, lists, and notes.",
    "slug": "dropaly",
    "scheme": "dropaly",
    "platforms": [
      "ios",
      "android"
    ],
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "icon": "./assets/images/icon.png",
    "ios": {
      "icon": {
        "light": "./assets/images/ios-icon-default.png",
        "dark": "./assets/images/ios-icon-dark.png",
        "tinted": "./assets/images/ios-icon-monochrome.png"
      },
      "bundleIdentifier": "com.anonymous.dropaly"
    },
    "android": {
      "package": "com.anonymous.dropaly",
      "icon": "./assets/images/icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "plugins": [
      "expo-router",
      "expo-system-ui",
      "expo-splash-screen",
      "expo-status-bar",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-font",
        {
          "android": {
            "fonts": [
              {
                "fontFamily": "Nunito Sans",
                "fontDefinitions": [
                  {
                    "path": "node_modules/@expo-google-fonts/nunito-sans/200ExtraLight/NunitoSans_200ExtraLight.ttf",
                    "weight": 200
                  },
                  {
                    "path": "node_modules/@expo-google-fonts/nunito-sans/200ExtraLight_Italic/NunitoSans_200ExtraLight_Italic.ttf",
                    "weight": 200,
                    "style": "italic"
                  },
                  {
                    "path": "node_modules/@expo-google-fonts/nunito-sans/300Light/NunitoSans_300Light.ttf",
                    "weight": 300
                  },
                  {
                    "path": "node_modules/@expo-google-fonts/nunito-sans/300Light_Italic/NunitoSans_300Light_Italic.ttf",
                    "weight": 300,
                    "style": "italic"
                  },
                  {
                    "path": "node_modules/@expo-google-fonts/nunito-sans/400Regular/NunitoSans_400Regular.ttf",
                    "weight": 400
                  },
                  {
                    "path": "node_modules/@expo-google-fonts/nunito-sans/400Regular_Italic/NunitoSans_400Regular_Italic.ttf",
                    "weight": 400,
                    "style": "italic"
                  },
                  {
                    "path": "node_modules/@expo-google-fonts/nunito-sans/500Medium/NunitoSans_500Medium.ttf",
                    "weight": 500
                  },
                  {
                    "path": "node_modules/@expo-google-fonts/nunito-sans/500Medium_Italic/NunitoSans_500Medium_Italic.ttf",
                    "weight": 500,
                    "style": "italic"
                  },
                  {
                    "path": "node_modules/@expo-google-fonts/nunito-sans/600SemiBold/NunitoSans_600SemiBold.ttf",
                    "weight": 600
                  },
                  {
                    "path": "node_modules/@expo-google-fonts/nunito-sans/600SemiBold_Italic/NunitoSans_600SemiBold_Italic.ttf",
                    "weight": 600,
                    "style": "italic"
                  },
                  {
                    "path": "node_modules/@expo-google-fonts/nunito-sans/700Bold/NunitoSans_700Bold.ttf",
                    "weight": 700
                  },
                  {
                    "path": "node_modules/@expo-google-fonts/nunito-sans/700Bold_Italic/NunitoSans_700Bold_Italic.ttf",
                    "weight": 700,
                    "style": "italic"
                  },
                  {
                    "path": "node_modules/@expo-google-fonts/nunito-sans/800ExtraBold/NunitoSans_800ExtraBold.ttf",
                    "weight": 800
                  },
                  {
                    "path": "node_modules/@expo-google-fonts/nunito-sans/800ExtraBold_Italic/NunitoSans_800ExtraBold_Italic.ttf",
                    "weight": 800,
                    "style": "italic"
                  },
                  {
                    "path": "node_modules/@expo-google-fonts/nunito-sans/900Black/NunitoSans_900Black.ttf",
                    "weight": 900
                  },
                  {
                    "path": "node_modules/@expo-google-fonts/nunito-sans/900Black_Italic/NunitoSans_900Black_Italic.ttf",
                    "weight": 900,
                    "style": "italic"
                  }
                ]
              },
              {
                "fontFamily": "Outfit",
                "fontDefinitions": [
                  {
                    "path": "node_modules/@expo-google-fonts/outfit/100Thin/Outfit_100Thin.ttf",
                    "weight": 100
                  },
                  {
                    "path": "node_modules/@expo-google-fonts/outfit/200ExtraLight/Outfit_200ExtraLight.ttf",
                    "weight": 200
                  },
                  {
                    "path": "node_modules/@expo-google-fonts/outfit/300Light/Outfit_300Light.ttf",
                    "weight": 300
                  },
                  {
                    "path": "node_modules/@expo-google-fonts/outfit/400Regular/Outfit_400Regular.ttf",
                    "weight": 400
                  },
                  {
                    "path": "node_modules/@expo-google-fonts/outfit/500Medium/Outfit_500Medium.ttf",
                    "weight": 500
                  },
                  {
                    "path": "node_modules/@expo-google-fonts/outfit/600SemiBold/Outfit_600SemiBold.ttf",
                    "weight": 600
                  },
                  {
                    "path": "node_modules/@expo-google-fonts/outfit/700Bold/Outfit_700Bold.ttf",
                    "weight": 700
                  },
                  {
                    "path": "node_modules/@expo-google-fonts/outfit/800ExtraBold/Outfit_800ExtraBold.ttf",
                    "weight": 800
                  },
                  {
                    "path": "node_modules/@expo-google-fonts/outfit/900Black/Outfit_900Black.ttf",
                    "weight": 900
                  }
                ]
              }
            ]
          },
          "ios": {
            "fonts": [
              "node_modules/@expo-google-fonts/nunito-sans/200ExtraLight/NunitoSans_200ExtraLight.ttf",
              "node_modules/@expo-google-fonts/nunito-sans/200ExtraLight_Italic/NunitoSans_200ExtraLight_Italic.ttf",
              "node_modules/@expo-google-fonts/nunito-sans/300Light/NunitoSans_300Light.ttf",
              "node_modules/@expo-google-fonts/nunito-sans/300Light_Italic/NunitoSans_300Light_Italic.ttf",
              "node_modules/@expo-google-fonts/nunito-sans/400Regular/NunitoSans_400Regular.ttf",
              "node_modules/@expo-google-fonts/nunito-sans/400Regular_Italic/NunitoSans_400Regular_Italic.ttf",
              "node_modules/@expo-google-fonts/nunito-sans/500Medium/NunitoSans_500Medium.ttf",
              "node_modules/@expo-google-fonts/nunito-sans/500Medium_Italic/NunitoSans_500Medium_Italic.ttf",
              "node_modules/@expo-google-fonts/nunito-sans/600SemiBold/NunitoSans_600SemiBold.ttf",
              "node_modules/@expo-google-fonts/nunito-sans/600SemiBold_Italic/NunitoSans_600SemiBold_Italic.ttf",
              "node_modules/@expo-google-fonts/nunito-sans/700Bold/NunitoSans_700Bold.ttf",
              "node_modules/@expo-google-fonts/nunito-sans/700Bold_Italic/NunitoSans_700Bold_Italic.ttf",
              "node_modules/@expo-google-fonts/nunito-sans/800ExtraBold/NunitoSans_800ExtraBold.ttf",
              "node_modules/@expo-google-fonts/nunito-sans/800ExtraBold_Italic/NunitoSans_800ExtraBold_Italic.ttf",
              "node_modules/@expo-google-fonts/nunito-sans/900Black/NunitoSans_900Black.ttf",
              "node_modules/@expo-google-fonts/nunito-sans/900Black_Italic/NunitoSans_900Black_Italic.ttf",
              "node_modules/@expo-google-fonts/outfit/100Thin/Outfit_100Thin.ttf",
              "node_modules/@expo-google-fonts/outfit/200ExtraLight/Outfit_200ExtraLight.ttf",
              "node_modules/@expo-google-fonts/outfit/300Light/Outfit_300Light.ttf",
              "node_modules/@expo-google-fonts/outfit/400Regular/Outfit_400Regular.ttf",
              "node_modules/@expo-google-fonts/outfit/500Medium/Outfit_500Medium.ttf",
              "node_modules/@expo-google-fonts/outfit/600SemiBold/Outfit_600SemiBold.ttf",
              "node_modules/@expo-google-fonts/outfit/700Bold/Outfit_700Bold.ttf",
              "node_modules/@expo-google-fonts/outfit/800ExtraBold/Outfit_800ExtraBold.ttf",
              "node_modules/@expo-google-fonts/outfit/900Black/Outfit_900Black.ttf"
            ]
          }
        }
      ]
    ]
  }
}
