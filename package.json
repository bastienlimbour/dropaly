{
  "name": "dropaly",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "engines": {
    "node": "^22.22.3",
    "pnpm": "^11.1.3"
  },
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "dev": "turbo watch dev --continue",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "dev:native": "turbo watch dev --continue --filter=native...",
    "dev:web": "turbo watch dev --continue --filter=web...",
    "dev:server": "turbo watch dev --continue --filter=server...",
    "db:push": "turbo run db:push --filter=@dropaly/db",
    "db:studio": "turbo run db:studio --filter=@dropaly/db",
    "db:generate": "turbo run db:generate --filter=@dropaly/db",
    "db:migrate": "turbo run db:migrate --filter=@dropaly/db",
    "db:start": "turbo run db:start --filter=@dropaly/db",
    "db:watch": "turbo run db:watch --filter=@dropaly/db",
    "db:stop": "turbo run db:stop --filter=@dropaly/db",
    "db:down": "turbo run db:down --filter=@dropaly/db"
  },
  "devDependencies": {
    "@dropaly/config": "workspace:*",
    "@types/node": "catalog:",
    "lefthook": "^2.1.8",
    "turbo": "^2.9.14",
    "typescript": "catalog:"
  }
}
