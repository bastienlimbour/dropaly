{
  "name": "@dropaly/api",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/index.server.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
