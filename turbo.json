{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "tasks": {
    "transit": {
      "dependsOn": ["^transit"]
    },
    "uniwind:generate": {
      "dependsOn": ["^uniwind:generate"],
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["transit"]
    },
    "lint": {
      "dependsOn": ["transit"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "oxlint.config.ts",
        "$TURBO_ROOT$/oxlint.config.ts",
        "$TURBO_ROOT$/packages/config/oxlint/**/*.ts"
      ]
    },
    "lint:fix": {
      "cache": false
    },
    "format": {
      "dependsOn": ["uniwind:generate"],
      "cache": false
    },
    "format:check": {
      "dependsOn": ["uniwind:generate"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "oxfmt.config.ts",
        "$TURBO_ROOT$/oxfmt.config.ts",
        "$TURBO_ROOT$/packages/config/oxfmt/*.ts"
      ]
    },
    "test": {
      "dependsOn": ["transit"]
    },
    "build": {
      "dependsOn": ["transit"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "//#openapi:generate": {
      "cache": false,
      "inputs": [
        "apps/api/src/**/*.ts",
        "apps/api/scripts/**/*.ts",
        "packages/api-client/scripts/**/*.ts",
        "packages/api-contract/openapi.json"
      ],
      "outputs": [
        "packages/api-contract/openapi.json",
        "packages/api-client/src/schema.d.ts"
      ]
    },
    "dev": {
      "dependsOn": ["uniwind:generate"],
      "persistent": true,
      "cache": false
    },
    "db:push": {
      "cache": false
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "db:start": {
      "cache": false
    },
    "db:stop": {
      "cache": false
    },
    "db:down": {
      "cache": false
    },
    "db:watch": {
      "cache": false,
      "persistent": true
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}
