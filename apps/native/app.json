{
  "expo": {
    "name": "Dropaly",
    "description": "Dropaly is an app for capturing and structuring thoughts into tasks, lists, and notes.",
    "slug": "dropaly",
    "scheme": "dropaly",
    "platforms": ["ios", "android", "web"],
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "web": { "bundler": "metro" },
    "plugins": ["expo-font", "expo-router"],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
