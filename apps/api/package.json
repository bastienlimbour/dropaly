{
  "name": "@dropaly/api",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "test": "vitest run",
    "build": "tsdown",
    "dev": "tsx watch src/index.ts",
    "openapi:generate": "tsx scripts/generate-openapi.ts",
    "start": "node dist/index.mjs",
    "clean": "git clean -xdf .cache .turbo dist node_modules"
  },
  "dependencies": {
    "@ai-sdk/google": "catalog:ai",
    "@dropaly/auth": "workspace:*",
    "@dropaly/db": "workspace:*",
    "@fastify/cors": "^11.2.0",
    "@fastify/swagger": "^9.6.1",
    "@fastify/swagger-ui": "^5.2.3",
    "@t3-oss/env-core": "catalog:",
    "ai": "catalog:ai",
    "better-auth": "catalog:auth",
    "dotenv": "catalog:",
    "drizzle-orm": "catalog:db",
    "drizzle-zod": "catalog:db",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^6.0.0",
    "pino-pretty": "^13.1.3",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@ai-sdk/devtools": "catalog:ai",
    "@dropaly/config": "workspace:*",
    "@types/node": "catalog:",
    "tsdown": "^0.22.0",
    "tsx": "^4.22.2",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
