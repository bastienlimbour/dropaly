    "next-themes": "catalog:ui",
    "react": "catalog:react",
    "react-dom": "catalog:react",
    "shadcn": "^3.8.5",
    "sonner": "catalog:ui",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@dropaly/config": "workspace:*",
    "@types/react": "catalog:react",
    "@types/react-dom": "catalog:react",
    "tailwindcss": "catalog:ui",
    "typescript": "catalog:"
  }
