{
  "name": "@dropaly/ui-mobile",
  "private": true,
  "type": "module",
  "exports": {
    "./globals.css": "./src/styles/globals.css",
    "./components/*": "./src/components/*.tsx",
    "./theme": "./src/lib/theme.ts",
    "./utils": "./src/lib/utils.ts"
  },
  "scripts": {
    "uniwind:generate": "pnpm --filter @dropaly/mobile exec uniwind generate-artifacts --css ../../packages/ui-mobile/src/styles/globals.css --dts ../../packages/ui-mobile/uniwind-types.d.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "clean": "git clean -xdf .cache .turbo dist node_modules"
  },
  "dependencies": {
    "@dropaly/ui": "workspace:*",
    "@rn-primitives/checkbox": "^1.4.0",
    "@rn-primitives/label": "^1.4.0",
    "@rn-primitives/separator": "^1.4.0",
    "@rn-primitives/slot": "^1.4.0",
    "@tabler/icons-react-native": "catalog:ui",
    "class-variance-authority": "catalog:ui"
  },
  "devDependencies": {
    "@dropaly/config": "workspace:*",
    "@types/react": "catalog:react",
    "tailwindcss": "catalog:ui",
    "typescript": "catalog:tooling"
  },
  "peerDependencies": {
    "react": "catalog:react",
    "react-native": "catalog:native",
    "react-native-reanimated": "catalog:native",
    "react-native-svg": "catalog:native",
    "react-native-worklets": "catalog:native",
    "uniwind": "catalog:native"
  }
}
