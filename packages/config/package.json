{
  "name": "@dropaly/config",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./oxfmt/*": "./oxfmt/*.ts",
    "./oxlint/*": "./oxlint/*",
    "./typescript/*": "./typescript/*"
  },
  "scripts": {
    "lint": "oxlint . --no-error-on-unmatched-pattern",
    "lint:fix": "oxlint . --fix --no-error-on-unmatched-pattern",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check"
  }
}
