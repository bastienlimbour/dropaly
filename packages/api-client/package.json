{
  "name": "@dropaly/api-client",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types/api-types.gen.ts"
  },
  "scripts": {
    "openapi:generate": "tsx scripts/generate-api-types.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "test": "vitest run",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "clean": "git clean -xdf .cache .turbo dist node_modules"
  },
  "dependencies": {
    "openapi-fetch": "^0.17.0"
  },
  "devDependencies": {
    "@dropaly/config": "workspace:*",
    "@types/node": "catalog:runtime",
    "openapi-typescript": "^7.13.0",
    "tsx": "catalog:tooling",
    "typescript": "catalog:tooling",
    "vitest": "catalog:tooling"
  }
}
