{
  "name": "@dropaly/api",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "openapi:generate": "tsx scripts/generate-openapi-schema.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "test": "vitest run",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "build": "tsdown",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.mjs",
    "clean": "git clean -xdf .cache .turbo dist node_modules"
  },
  "dependencies": {
    "@ai-sdk/gateway": "catalog:ai",
    "@ai-sdk/google": "catalog:ai",
    "@dropaly/auth": "workspace:*",
    "@dropaly/db": "workspace:*",
    "@fastify/cors": "^11.2.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@t3-oss/env-core": "catalog:runtime",
    "ai": "catalog:ai",
    "better-auth": "catalog:auth",
    "dotenv": "catalog:runtime",
    "drizzle-orm": "catalog:db",
    "drizzle-zod": "catalog:db",
    "fastify": "^5.9.0",
    "fastify-plugin": "^6.0.0",
    "fastify-type-provider-zod": "^7.0.0",
    "pg": "catalog:db",
    "pino-pretty": "^13.1.3",
    "zod": "catalog:runtime"
  },
  "devDependencies": {
    "@ai-sdk/devtools": "catalog:ai",
    "@dropaly/config": "workspace:*",
    "@types/node": "catalog:runtime",
    "@types/pg": "catalog:db",
    "tsdown": "^0.22.3",
    "tsx": "catalog:tooling",
    "typescript": "catalog:tooling",
    "vitest": "catalog:tooling"
  }
}
