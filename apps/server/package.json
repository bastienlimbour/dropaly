{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "test": "vitest run",
    "build": "tsdown",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.mjs",
    "clean": "git clean -xdf .cache .turbo dist node_modules"
  },
  "dependencies": {
    "@dropaly/api": "workspace:*",
    "@dropaly/auth": "workspace:*",
    "@dropaly/db": "workspace:*",
    "@dropaly/env": "workspace:*",
    "@fastify/cors": "^11.2.0",
    "@trpc/server": "catalog:trpc",
    "better-auth": "catalog:auth",
    "fastify": "^5.8.5",
    "fastify-type-provider-zod": "^6.0.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@dropaly/config": "workspace:*",
    "@types/node": "catalog:",
    "pino-pretty": "^13.1.3",
    "tsdown": "^0.22.0",
    "tsx": "^4.22.2",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
