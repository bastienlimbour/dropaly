{
  "$schema": "../../../node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "eslint",
    "typescript",
    "unicorn",
    "oxc",
    "import",
    "promise",
    "react"
  ],
  "settings": {
    "react": {
      "version": "19.2.0"
    }
  },
  "rules": {
    "react/react-in-jsx-scope": "off"
  }
}
