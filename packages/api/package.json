{
  "name": "@dropaly/api",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./server": {
      "types": "./dist/index.server.d.ts",
      "default": "./src/index.server.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "clean": "git clean -xdf .cache .turbo dist node_modules"
  },
  "dependencies": {
    "@dropaly/db": "workspace:*",
    "@ai-sdk/google": "catalog:ai",
    "@trpc/server": "catalog:trpc",
    "drizzle-orm": "catalog:db",
    "drizzle-zod": "catalog:db",
    "ai": "catalog:ai",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@ai-sdk/devtools": "catalog:ai",
    "@dropaly/config": "workspace:*",
    "typescript": "catalog:"
  }
}
