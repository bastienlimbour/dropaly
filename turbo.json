{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "concurrency": "100%",
  "futureFlags": {
    "watchUsingTaskInputs": true
  },
  "tasks": {
    "transit": {
      "dependsOn": [
        "^transit"
      ]
    },
    "uniwind:generate": {
      "dependsOn": [
        "^uniwind:generate"
      ],
      "cache": false
    },
    "//#openapi:generate": {
      "cache": false,
      "inputs": [
        "apps/api/src/**/*.ts",
        "apps/api/scripts/generate-openapi-schema.ts",
        "packages/api-client/scripts/generate-api-types.ts"
      ],
      "outputs": [
        "apps/api/openapi/openapi.json",
        "packages/api-client/src/types/api-types.gen.ts"
      ]
    },
    "typecheck": {
      "dependsOn": [
        "transit"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        "tsconfig.json",
        "$TURBO_ROOT$/tsconfig.json",
        "$TURBO_ROOT$/packages/config/typescript/**/*.json"
      ]
    },
    "lint": {
      "dependsOn": [
        "transit"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        "oxlint.config.ts",
        "$TURBO_ROOT$/oxlint.config.ts",
        "$TURBO_ROOT$/packages/config/oxlint/**/*.ts"
      ]
    },
    "lint:fix": {
      "cache": false
    },
    "test": {
      "dependsOn": [
        "transit"
      ]
    },
    "format": {
      "dependsOn": [
        "uniwind:generate"
      ],
      "cache": false
    },
    "format:check": {
      "dependsOn": [
        "uniwind:generate"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        "oxfmt.config.ts",
        "$TURBO_ROOT$/oxfmt.config.ts",
        "$TURBO_ROOT$/packages/config/oxfmt/**/*.ts"
      ]
    },
    "build": {
      "dependsOn": [
        "transit"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "dev": {
      "dependsOn": [
        "uniwind:generate"
      ],
      "persistent": true,
      "cache": false
    },
    "db:push": {
      "cache": false
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "db:start": {
      "cache": false
    },
    "db:stop": {
      "cache": false
    },
    "db:down": {
      "cache": false
    },
    "db:watch": {
      "cache": false,
      "persistent": true
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}
