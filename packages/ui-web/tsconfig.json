{
  "extends": "@dropaly/config/tsconfig.declaration-package.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "rootDir": "src",
    "types": ["node", "react", "react-dom"],
    "paths": {
      "@dropaly/ui-web/*": ["./src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
