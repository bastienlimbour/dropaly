{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": ["@dropaly/config/typescript/tsconfig.base.json", "expo/tsconfig.base"],
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "**/*.js"],
  "exclude": ["node_modules", "dist", "ios", "android"]
}
