{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "incremental": true,
    "noEmit": false,
    "outDir": "${configDir}/dist",
    "tsBuildInfoFile": "${configDir}/.cache/tsbuildinfo.json"
  }
}
