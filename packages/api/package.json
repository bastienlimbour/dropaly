    "drizzle-zod": "catalog:db",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@ai-sdk/devtools": "catalog:ai",
    "@dropaly/config": "workspace:*",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
