{
  "name": "@dropaly/env",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./src/server.ts"
    },
    "./web": {
      "types": "./dist/web.d.ts",
      "default": "./src/web.ts"
    },
    "./native": {
      "types": "./dist/native.d.ts",
      "default": "./src/native.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@t3-oss/env-core": "^0.13.1",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@dropaly/config": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:"
  }
}
