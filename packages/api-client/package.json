{
  "name": "@dropaly/api-client",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types/api-types.gen.ts"
  },
  "scripts": {
    "openapi:generate": "tsx scripts/generate-api-types.ts",
