{
  "$schema": "../../node_modules/oxlint/configuration_schema.json",
  "extends": ["../../packages/config/oxlint/base.json"],
  "overrides": [
    {
      "files": ["src/index.server.ts", "src/index.native.ts"],
      "env": { "builtin": true, "node": true },
      "plugins": [
        "eslint",
        "typescript",
        "unicorn",
        "oxc",
        "import",
        "promise",
        "node"
      ]
    },
    { "files": ["src/index.web.ts"], "env": { "builtin": true, "browser": true } }
  ]
}
