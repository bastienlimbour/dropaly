{
  "name": "@dropaly/auth",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "auth:generate": "pnpm dlx @better-auth/cli@latest generate --config scripts/auth.cli.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "clean": "git clean -xdf .cache .turbo dist node_modules"
  },
  "dependencies": {
    "@better-auth/expo": "catalog:auth",
    "@dropaly/db": "workspace:*",
    "@polar-sh/better-auth": "catalog:auth",
    "@polar-sh/sdk": "catalog:auth"
  },
  "devDependencies": {
    "@dropaly/config": "workspace:*",
    "typescript": "catalog:tooling"
  },
  "peerDependencies": {
    "better-auth": "catalog:auth"
  }
}
