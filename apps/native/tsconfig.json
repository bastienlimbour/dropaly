{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": ["@dropaly/config/typescript/tsconfig.base.json", "expo/tsconfig.base"],
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "src/**/*",
    "*.config.*",
    ".expo/types/**/*.ts",
    "*.d.ts",
    "expo-env.d.ts"
  ],
  "exclude": ["node_modules", "babel.config.js", "jest.config.js", "android", "ios"]
}
