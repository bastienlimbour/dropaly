{
  "name": "@dropaly/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./tokens.css": "./src/styles/tokens.css",
    "./lib/*": {
      "source": "./src/lib/*.ts",
      "types": "./src/lib/*.ts",
      "default": "./src/lib/*.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false --tsBuildInfoFile .cache/typecheck.tsbuildinfo",
    "clean": "git clean -xdf .cache .turbo dist node_modules"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@dropaly/config": "workspace:*",
    "typescript": "catalog:"
  }
}
