{
  "name": "dropaly",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "postinstall": "pnpm run uniwind:generate",
    "uniwind:generate": "turbo run uniwind:generate --filter=@dropaly/ui-mobile --filter=@dropaly/mobile",
    "typecheck": "turbo run typecheck --continue",
    "lint": "turbo run lint --continue",
    "lint:fix": "turbo run lint:fix",
    "lint:open": "pnpm exec oxlint -f unix | awk -F: 'NF>1{print $1}' | sort -u | xargs cursor",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "test": "turbo run test",
    "check": "turbo run typecheck lint format:check test",
    "build": "turbo run build",
    "openapi:generate": "pnpm --filter api openapi:generate && pnpm --filter @dropaly/api-client openapi:generate",
    "openapi:watch": "turbo watch //#openapi:generate",
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=@dropaly/api",
    "dev:web": "turbo run dev --filter=@dropaly/web",
    "dev:mobile": "turbo run dev --filter=@dropaly/mobile",
    "db:push": "turbo run db:push --filter=@dropaly/db",
    "db:generate": "turbo run db:generate --filter=@dropaly/db",
    "db:migrate": "turbo run db:migrate --filter=@dropaly/db",
    "db:start": "turbo run db:start --filter=@dropaly/db",
    "db:stop": "turbo run db:stop --filter=@dropaly/db",
    "db:down": "turbo run db:down --filter=@dropaly/db",
    "db:watch": "turbo run db:watch --filter=@dropaly/db",
    "db:studio": "turbo run db:studio --filter=@dropaly/db",
    "clean": "turbo run clean && git clean -xdf .cache .turbo dist node_modules"
  },
  "devDependencies": {
    "@dropaly/config": "workspace:*",
    "@types/node": "catalog:",
    "lefthook": "^2.1.8",
    "oxfmt": "0.52.0",
    "oxlint": "1.67.0",
    "oxlint-tsgolint": "0.23.0",
    "turbo": "^2.9.14",
    "typescript": "catalog:"
  },
  "engines": {
    "node": "^22.22.3",
    "pnpm": "^11.1.3"
  },
  "packageManager": "pnpm@11.1.3"
}
